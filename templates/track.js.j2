(function () {
  var scriptEl = document.currentScript;
  var siteKey = scriptEl && scriptEl.getAttribute('data-site');
  if (!siteKey) { return; }

  var COLLECT_URL = '{{ collect_url }}';
  var pageviewId = null;
  var pageStart = null;
  var durationSent = false;

  function getSessionId() {
    try {
      var existing = sessionStorage.getItem('__wt_sid');
      if (existing) return existing;
      var sid = Math.random().toString(36).slice(2) + Date.now().toString(36);
      sessionStorage.setItem('__wt_sid', sid);
      return sid;
    } catch (e) {
      return 'no-storage';
    }
  }

  function genId() {
    return Math.random().toString(36).slice(2) + Date.now().toString(36);
  }

  function send(payload, useBeacon) {
    payload.site_key = siteKey;
    payload.session_id = getSessionId();
    var body = JSON.stringify(payload);
    if (useBeacon && navigator.sendBeacon) {
      try {
        // text/plain avoids a CORS preflight on unload; the server parses the raw body as JSON.
        navigator.sendBeacon(COLLECT_URL, new Blob([body], { type: 'text/plain' }));
        return;
      } catch (e) {}
    }
    try {
      fetch(COLLECT_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: body,
        keepalive: true,
        mode: 'cors',
      }).catch(function () {});
    } catch (e) {}
  }

  function trackPageview() {
    pageviewId = genId();
    pageStart = Date.now();
    durationSent = false;
    send({
      type: 'pageview',
      url: location.href,
      path: location.pathname,
      referrer: document.referrer || '',
      pageview_id: pageviewId,
    });
  }

  function trackEvent(name, data) {
    send({
      type: 'event',
      url: location.href,
      path: location.pathname,
      event_name: name,
      event_data: data || {},
    });
  }

  function sendDuration() {
    if (durationSent || !pageviewId || !pageStart) return;
    durationSent = true;
    send({
      type: 'duration',
      pageview_id: pageviewId,
      duration_ms: Date.now() - pageStart,
    }, true);
  }

  // expose global for custom events, e.g. webtrack('event', 'signup_click', {plan: 'pro'})
  window.webtrack = function (kind, name, data) {
    if (kind === 'event') trackEvent(name, data);
  };

  // auto-track clicks on elements marked with data-wt-event="name"
  document.addEventListener('click', function (e) {
    var el = e.target.closest && e.target.closest('[data-wt-event]');
    if (el) {
      trackEvent(el.getAttribute('data-wt-event'), { text: el.textContent.trim().slice(0, 80) });
    }
  });

  // track SPA route changes
  var origPushState = history.pushState;
  history.pushState = function () {
    sendDuration();
    origPushState.apply(this, arguments);
    trackPageview();
  };
  window.addEventListener('popstate', function () {
    sendDuration();
    trackPageview();
  });

  // fires when the tab is backgrounded/closed — the most reliable place to
  // capture "how long were they actually on this page"
  document.addEventListener('visibilitychange', function () {
    if (document.visibilityState === 'hidden') sendDuration();
  });
  window.addEventListener('pagehide', sendDuration);

  trackPageview();
})();
